---
import { Separator } from "@/components/ui/separator";

interface Props {
  destinationCount: number;
  totalPlaces: number;
}

const { destinationCount, totalPlaces } = Astro.props;
---

<div class="pt-14 sm:pt-20 pb-12 sm:pb-16 border-b border-border">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-8">

    <div>
      <h1 class="text-5xl sm:text-7xl lg:text-[5.5rem] font-black leading-none tracking-tighter text-foreground">
        Thrift Family Travels
      </h1>
      <p class="text-muted-foreground text-base sm:text-lg mt-5 max-w-md leading-relaxed">
        Every place we've been together, kept here so we never forget.
      </p>
    </div>

    <div class="flex sm:flex-col gap-8 sm:gap-5 sm:text-right pb-1 shrink-0">
      <div>
        <div class="text-4xl sm:text-6xl font-black text-foreground tabular-nums">{destinationCount}</div>
        <div class="text-sm text-muted-foreground mt-0.5">destinations</div>
      </div>
      <div class="hidden sm:block">
        <Separator />
      </div>
      <div>
        <div class="text-4xl sm:text-6xl font-black text-foreground tabular-nums">{totalPlaces}</div>
        <div class="text-sm text-muted-foreground mt-0.5">places logged</div>
      </div>
    </div>

  </div>
</div>