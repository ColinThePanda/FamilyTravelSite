---
import HomeLayout from "@/layouts/home.astro";
import HomeHeader from "@/components/HomeHeader.astro";
import DestinationRow from "@/components/DestinationRow.astro";

const destinations = [
  { slug: "kyoto",    name: "Kyoto",        country: "Japan",     region: "Asia",       year: 2023, img: "https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?w=900&q=80", places: 24 },
  { slug: "amalfi",   name: "Amalfi Coast", country: "Italy",     region: "Europe",     year: 2022, img: "https://images.unsplash.com/photo-1745435797169-04e21114a272?w=900&q=80", places: 18 },
  { slug: "patagonia",name: "Patagonia",    country: "Argentina", region: "S. America", year: 2024, img: "https://images.unsplash.com/photo-1531761535209-180857e963b9?w=900&q=80", places: 18 },
  { slug: "santorini",name: "Santorini",    country: "Greece",    region: "Europe",     year: 2023, img: "https://images.unsplash.com/photo-1570077188670-e3a8d69ac5ff?w=900&q=80", places: 14 },
  { slug: "tokyo",    name: "Tokyo",        country: "Japan",     region: "Asia",       year: 2021, img: "https://images.unsplash.com/photo-1540959733332-eab4deabeeaf?w=900&q=80", places: 31 },
  { slug: "lisbon",   name: "Lisbon",       country: "Portugal",  region: "Europe",     year: 2022, img: "https://images.unsplash.com/photo-1585208798174-6cedd86e019a?w=900&q=80", places: 20 },
];

const totalPlaces = destinations.reduce((s, d) => s + d.places, 0);
---

<HomeLayout title="Home">
  <div class="max-w-5xl mx-auto px-4 sm:px-8 lg:px-10">

    <HomeHeader
      destinationCount={destinations.length}
      totalPlaces={totalPlaces}
    />

    <div>
      {destinations.map((d, i) => (
        <DestinationRow
          slug={d.slug}
          name={d.name}
          country={d.country}
          region={d.region}
          year={d.year}
          img={d.img}
          places={d.places}
          index={i + 1}
        />
      ))}
    </div>

    <div class="py-6 text-right">
      <p class="text-xs text-muted-foreground">Last updated March 2026</p>
    </div>

  </div>
</Layout>